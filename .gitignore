# --- [BPSR PROJECT SPECIFIC] Unsloth & ML Cache ---
# Hardware-specific compiled kernels and training data
unsloth_compiled_cache/
.triton/
lora_dataset/

# --- [BPSR PROJECT SPECIFIC] llama.cpp ---
# Ignore the entire directory if you're using it as a local tool
/llama.cpp/

# --- [BPSR PROJECT SPECIFIC] Machine Learning Artifacts ---
# We never want to push multi-GB weights or GGUFs to GitHub
*.gguf
*.safetensors
*.bin
*.pt
*.pth
*.ckpt
*.onnx

# --- [BPSR PROJECT SPECIFIC] Research & Build Folders ---
/models/
/outputs/
/datasets/
model_f16/
model_f16_clean/
BlueProtocol_JP_KO_Translator/
BlueProtocol_JP_KO_Translator-merged-16bit/
# Ignore all files in data, but keep the folder structure
/data/**/*
!/data/**/.gitkeep

# --- [BPSR PROJECT SPECIFIC] Experiment Tracking ---
mlruns/
artifacts/
.mlflow/

# --- [GITHUB TEMPLATE] Byte-compiled / optimized / DLL files ---
__pycache__/
*.py[codz]
*$py.class
*.so

# --- [GITHUB TEMPLATE] Environments ---
.env
.envrc
.venv
env/
venv/
ENV/

# --- [GITHUB TEMPLATE] Editor & Tooling ---
.idea/
.vscode/
.cursorignore
.cursorindexingignore